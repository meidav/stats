# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Database Configuration
# Local dev:
DATABASE_PATH=stats.db
DATABASE_PATH_LOCAL=stats.db
# Railway production (with volume mounted at /data):
# DATABASE_PATH=/data/stats.db

# Timezone Configuration
TIME_OFFSET=-8

# Game Settings
MIN_DELTA=30
MIN_DELTA_TEAMS=50
MIN_DELTA_PLAYER=40

# Railway / Production
# WEB_CONCURRENCY=2
# CORS_ORIGINS=https://playtracker.org

# PythonAnywhere API (legacy deployment)
PA_USERNAME=yourusername
PA_API_TOKEN=your-api-token-here
PA_DOMAIN=yourusername.pythonanywhere.com
